---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogUrl?: string;
}

const {
  title,
  description,
  ogImage = '/images/og-image.jpg',
  ogUrl = 'https://sacart.co',
} = Astro.props;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "SAC_ART",
  "description": "Pintamos retratos de mascotas en acrílico sobre lienzo, paisajes y fundas personalizadas por encargo. Envíos a todo Colombia.",
  "url": ogUrl,
  "telephone": "+573001234567",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "CO"
  },
  "sameAs": [
    "https://www.instagram.com/sac_artx"
  ],
  "priceRange": "$$",
  "currenciesAccepted": "COP",
  "paymentAccepted": "Nequi, Daviplata, Transferencia bancaria, Efectivo"
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#C4714F" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="SAC_ART" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts — preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  </head>

  <body>
    <slot />

    <!-- Scroll Reveal -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
