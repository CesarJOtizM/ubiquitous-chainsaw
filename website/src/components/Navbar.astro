---
import { useTranslations } from '../i18n/utils';

export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const WA_BASE = 'https://wa.me/573001234567?text=';
const WA_URL = `${WA_BASE}${t('nav.cta') === 'Order via WhatsApp' ? 'Hello!%20I\'d%20like%20to%20commission%20a%20portrait' : 'Hola!%20Me%20gustar%C3%ADa%20encargar%20un%20retrato'}`;

const otherLang = lang === 'es' ? 'en' : 'es';
const langSwitchHref = lang === 'es' ? '/en/' : '/';
---

<header id="navbar" class="navbar">
  <div class="navbar__inner container">
    <!-- Logo -->
    <a href={lang === 'en' ? '/en/' : '/'} class="navbar__logo" aria-label="SAC_ART — {lang === 'en' ? 'home' : 'inicio'}">
      SAC_ART
    </a>

    <!-- Desktop Nav -->
    <nav class="navbar__desktop" aria-label={t('nav.desktopLabel')}>
      <a href="#servicios" class="navbar__link">{t('nav.services')}</a>
      <a href="#galeria" class="navbar__link">{t('nav.gallery')}</a>
      <a href="#proceso" class="navbar__link">{t('nav.process')}</a>
      <a href="#contacto" class="navbar__link">{t('nav.contact')}</a>
      <a
        href={langSwitchHref}
        class="navbar__lang-switch"
        aria-label={t('nav.langSwitchLabel')}
        hreflang={otherLang}
      >
        {t('nav.langSwitch')}
      </a>
      <a href={WA_URL} class="btn btn-whatsapp navbar__cta" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        {t('nav.whatsapp')}
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="navbar__hamburger"
      aria-label={t('nav.menuOpen')}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<!-- Mobile Overlay Menu -->
<div id="mobile-menu" class="mobile-menu" aria-hidden="true" role="dialog" aria-label={t('nav.mobileLabel')}>
  <button id="menu-close" class="mobile-menu__close" aria-label={t('nav.menuClose')}>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M18 6L6 18M6 6l12 12"/>
    </svg>
  </button>
  <nav class="mobile-menu__nav" aria-label={t('nav.mobileLabel')}>
    <a href="#servicios" class="mobile-menu__link">{t('nav.services')}</a>
    <a href="#galeria" class="mobile-menu__link">{t('nav.gallery')}</a>
    <a href="#proceso" class="mobile-menu__link">{t('nav.process')}</a>
    <a href="#contacto" class="mobile-menu__link">{t('nav.contact')}</a>
    <a
      href={langSwitchHref}
      class="mobile-menu__lang-switch"
      aria-label={t('nav.langSwitchLabel')}
      hreflang={otherLang}
    >
      {t('nav.langSwitch')}
    </a>
    <a href={WA_URL} class="mobile-menu__wa" target="_blank" rel="noopener noreferrer">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      {t('nav.waOrder')}
    </a>
  </nav>
</div>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .navbar.scrolled {
    background: rgba(250, 248, 243, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 var(--color-border);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .navbar__logo {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s;
  }

  .navbar__logo:hover {
    color: var(--color-accent);
  }

  .navbar__desktop {
    display: flex;
    align-items: center;
    gap: 36px;
  }

  .navbar__link {
    font-size: 15px;
    font-weight: 400;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
    position: relative;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-accent);
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  .navbar__link:hover {
    color: var(--color-text);
  }

  .navbar__link:hover::after {
    transform: scaleX(1);
  }

  /* Language switcher pill */
  .navbar__lang-switch {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-decoration: none;
    border: 1.5px solid var(--color-border);
    border-radius: 20px;
    padding: 4px 12px;
    transition: border-color 0.2s, color 0.2s;
  }

  .navbar__lang-switch:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .navbar__cta {
    padding: 10px 20px;
    font-size: 14px;
    border-radius: 4px;
  }

  /* Hamburger */
  .navbar__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 8px;
  }

  .navbar__hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .navbar__hamburger.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .navbar__hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .navbar__hamburger.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    inset: 0;
    background: var(--color-bg);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu.open {
    transform: translateX(0);
  }

  .mobile-menu__close {
    position: absolute;
    top: 24px;
    right: 24px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: 8px;
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .mobile-menu__link {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 300;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s;
    padding: 8px 24px;
  }

  .mobile-menu__link:hover {
    color: var(--color-accent);
  }

  /* Mobile language switcher */
  .mobile-menu__lang-switch {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-decoration: none;
    border: 1.5px solid var(--color-border);
    border-radius: 20px;
    padding: 6px 20px;
    margin-top: 8px;
    transition: border-color 0.2s, color 0.2s;
  }

  .mobile-menu__lang-switch:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .mobile-menu__wa {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 16px;
    background: var(--color-whatsapp);
    color: #fff;
    padding: 14px 28px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 16px;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .navbar__desktop {
      display: none;
    }

    .navbar__hamburger {
      display: flex;
    }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('menu-close');
  const mobileLinks = document.querySelectorAll('.mobile-menu__link, .mobile-menu__wa');

  // Scroll behavior
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  }, { passive: true });

  // Open/close menu
  function openMenu() {
    mobileMenu?.classList.add('open');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    toggle?.classList.add('active');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu?.classList.remove('open');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    toggle?.classList.remove('active');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('open');
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
