    title: t('gallery.item6.title'),
    technique: acrylic('40×40cm'),
    gradient: 'linear-gradient(135deg, #C4714F33, #D4845F55)',
    height: 300,
    w: 900,
    h: 900,
  },
  {
    id: 7,
    category: 'paisajes',
    title: t('gallery.item7.title'),
    technique: acrylic('50×40cm'),
    gradient: 'linear-gradient(135deg, #D4845F44, #8A9E8C44)',
