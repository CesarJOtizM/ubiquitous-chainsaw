---
import { useTranslations } from '../i18n/utils';

export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const WA_URL = `https://wa.me/573016584401?text=${t('hero.waMsg')}`;
---

<section class="hero" aria-label="Hero — Sac_Artx">
  <!-- Watercolor blobs -->
  <div class="hero__blobs" aria-hidden="true">
    <div class="hero__blob hero__blob--pink"></div>
    <div class="hero__blob hero__blob--teal"></div>
    <div class="hero__blob hero__blob--lavender"></div>
    <div class="hero__blob hero__blob--pink2"></div>
    <!-- Brush stroke decorations -->
    <div class="brush-deco brush-deco--medium brush-g" aria-hidden="true" style="width:780px;height:190px;top:-30px;right:-100px;opacity:0.10;transform:rotate(-8deg)"></div>
    <div class="brush-deco brush-deco--pale brush-h" aria-hidden="true" style="width:560px;height:140px;bottom:80px;left:-80px;opacity:0.14;transform:rotate(6deg)"></div>
    <div class="brush-deco brush-deco--gold brush-i" aria-hidden="true" style="width:320px;height:80px;top:55%;left:38%;opacity:0.07;transform:rotate(-3deg)"></div>
    <svg class="hero__gold-lines" viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M 60 80 Q 200 20 380 120 T 720 80" stroke="#C9A227" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.5" fill="none"/>
      <path d="M 0 300 Q 150 240 300 320 T 600 280" stroke="#C9A227" stroke-width="1" stroke-dasharray="4 6" opacity="0.35" fill="none"/>
      <path d="M 500 480 Q 620 420 780 500" stroke="#C9A227" stroke-width="1.5" stroke-dasharray="5 5" opacity="0.4" fill="none"/>
    </svg>
  </div>

  <div class="hero__inner container">
    <!-- Left: hero image -->
    <div class="hero__image-wrap reveal">
      <div class="hero__placeholder" aria-label={t('hero.imageAlt')}>
        <img
          src="/images/bases-acrilicas/15.jpeg"
          alt={t('hero.imageAlt')}
          class="hero__img"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <!-- Decorative accent -->
      <div class="hero__deco" aria-hidden="true"></div>
    </div>

    <!-- Right: content -->
    <div class="hero__content">
      <p class="hero__label reveal">{t('hero.label')}</p>
      <h1 class="hero__title reveal">
        {t('hero.title')}<br />
        <em>{t('hero.titleEm')}</em>
      </h1>
      <p class="hero__tagline reveal">
        {t('hero.tagline')}
      </p>
      <div class="hero__ctas reveal">
        <a href={WA_URL} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
          {t('hero.ctaPrimary')}
        </a>
        <a href="#galeria" class="btn btn-outline">
          {t('hero.ctaSecondary')}
        </a>
      </div>

      <!-- Stats / Social proof -->
      <div class="hero__stats reveal">
        <div class="hero__stat">
          <strong>{t('hero.stat1Value')}</strong>
          <span>{t('hero.stat1Label')}</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <strong>{t('hero.stat2Value')}</strong>
          <span>{t('hero.stat2Label')}</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <strong>{t('hero.stat3Value')}</strong>
          <span>{t('hero.stat3Label')}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <div class="hero__scroll-mouse">
      <div class="hero__scroll-dot"></div>
    </div>
    <span>{t('hero.scroll')}</span>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--color-bg);
    padding-top: 72px;
    position: relative;
    overflow: hidden;
  }

  /* No ::before polygon — background handled globally */

  /* Watercolor blobs */
  .hero__blobs {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero__blob {
    position: absolute;
    filter: blur(48px);
    opacity: 0.45;
  }

  .hero__blob--pink {
    width: 520px;
    height: 420px;
    background: #F5A0C0;
    border-radius: 62% 38% 46% 54% / 60% 44% 56% 40%;
    top: -80px;
    right: -60px;
  }

  .hero__blob--teal {
    width: 380px;
    height: 360px;
    background: #7CC4BB;
    border-radius: 40% 60% 55% 45% / 50% 60% 40% 50%;
    top: 30%;
    right: 5%;
    opacity: 0.35;
  }

  .hero__blob--lavender {
    width: 300px;
    height: 280px;
    background: #C8A8D8;
    border-radius: 70% 30% 50% 50% / 40% 60% 40% 60%;
    bottom: 5%;
    left: -40px;
    opacity: 0.35;
  }

  .hero__blob--pink2 {
    width: 260px;
    height: 240px;
    background: #F5B8D0;
    border-radius: 50% 50% 38% 62% / 55% 45% 55% 45%;
    top: 55%;
    left: 25%;
    opacity: 0.3;
  }

  .hero__gold-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
    padding-top: clamp(40px, 6vh, 80px);
    padding-bottom: clamp(40px, 6vh, 80px);
    position: relative;
    z-index: 2;
  }

  /* Image area */
  .hero__image-wrap {
    position: relative;
  }

  .hero__placeholder {
    aspect-ratio: 1;
    border-radius: 8px;
    background: linear-gradient(135deg, #F07050 0%, #F5A0C0 50%, #E8F6F4 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(240, 112, 80, 0.2), 0 0 0 4px rgba(201, 162, 39, 0.15);
  }

  .hero__placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(44, 44, 44, 0.12) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__placeholder-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.9);
    position: relative;
    z-index: 1;
  }

  .hero__placeholder-icon {
    font-size: 48px;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.2));
  }

  .hero__placeholder-text {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .hero__placeholder-sub {
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.08em;
    opacity: 0.75;
    text-transform: uppercase;
  }

  .hero__deco {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: 80px;
    height: 80px;
    border: 2px solid var(--color-gold);
    border-radius: 4px;
    opacity: 0.6;
    z-index: -1;
  }

  /* Content */
  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero__label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-sage);
    margin-bottom: 16px;
    transition-delay: 0.1s;
  }

  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(44px, 7vw, 80px);
    font-weight: 300;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: 24px;
    transition-delay: 0.2s;
  }

  .hero__title em {
    font-style: italic;
    color: var(--color-accent);
  }

  .hero__tagline {
    font-size: clamp(15px, 1.5vw, 18px);
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 36px;
    transition-delay: 0.3s;
  }

  .hero__ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 48px;
    transition-delay: 0.4s;
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 18px 24px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    transition-delay: 0.5s;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 3px;
    flex: 1;
    padding: 0 12px;
  }

  .hero__stat:first-child {
    padding-left: 0;
  }

  .hero__stat strong {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 500;
    color: var(--color-accent);
    line-height: 1;
  }

  .hero__stat span {
    font-size: 12px;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .hero__stat-divider {
    width: 1px;
    height: 36px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--color-text-muted);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    z-index: 1;
    animation: float 2.5s ease-in-out infinite;
  }

  .hero__scroll-mouse {
    width: 22px;
    height: 34px;
    border: 1.5px solid var(--color-border);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .hero__scroll-dot {
    width: 3px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 2px;
    animation: scroll-dot 2s ease-in-out infinite;
  }

  @keyframes float {
    0%   { transform: translateX(-50%) translateY(0); }
    40%  { transform: translateX(-50%) translateY(10px); }
    60%  { transform: translateX(-50%) translateY(6px); }
    80%  { transform: translateX(-50%) translateY(10px); }
    100% { transform: translateX(-50%) translateY(0); }
  }

  @keyframes scroll-dot {
    0% { transform: translateY(0); opacity: 1; }
    80% { transform: translateY(12px); opacity: 0; }
    100% { transform: translateY(0); opacity: 0; }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero {
      padding-top: 64px;
    }

    .hero::before {
      display: none;
    }

    .hero__inner {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-top: 24px;
      padding-bottom: 32px;
    }

    .hero__image-wrap {
      order: -1;
    }

    .hero__placeholder {
      aspect-ratio: 4/3;
      max-height: 280px;
    }

    .hero__tagline {
      font-size: 15px;
      max-width: 100%;
    }

    .hero__ctas {
      flex-direction: column;
      gap: 12px;
    }

    .hero__ctas .btn {
      text-align: center;
      justify-content: center;
      width: 100%;
    }

    .hero__stats {
      gap: 0;
      justify-content: space-between;
      padding: 14px 16px;
    }

    .hero__stat {
      flex: 1;
      align-items: center;
      text-align: center;
      padding: 0 10px;
    }

    .hero__stat strong {
      font-size: 20px;
    }

    .hero__stat span {
      font-size: 11px;
      white-space: normal;
      text-align: center;
      line-height: 1.3;
    }

    .hero__stat-divider {
      width: 1px;
      height: 28px;
    }

    .hero__scroll {
      display: none;
    }
  }

  @media (max-width: 400px) {
    .hero__stats {
      padding: 12px 10px;
      gap: 0;
    }

    .hero__stat {
      padding: 0 8px;
    }

    .hero__stat strong {
      font-size: 16px;
    }

    .hero__stat span {
      font-size: 9px;
      line-height: 1.2;
    }
  }
</style>
