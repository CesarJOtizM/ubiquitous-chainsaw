---
import { useTranslations } from '../i18n/utils';

export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const WA_URL = `https://wa.me/573016584401?text=${t('process.waMsg')}`;

const steps = [
  {
    number: '01',
    icon: '📷',
    title: t('process.step1.title'),
    desc: t('process.step1.desc'),
  },
  {
    number: '02',
    icon: '✏️',
    title: t('process.step2.title'),
    desc: t('process.step2.desc'),
  },
  {
    number: '03',
    icon: '✅',
    title: t('process.step3.title'),
    desc: t('process.step3.desc'),
  },
  {
    number: '04',
    icon: '🎨',
    title: t('process.step4.title'),
    desc: t('process.step4.desc'),
  },
  {
    number: '05',
    icon: '📦',
    title: t('process.step5.title'),
    desc: t('process.step5.desc'),
  },
];
---

<section id="proceso" class="section process" aria-labelledby="process-title">
  <div class="container">
    <div class="process__header reveal">
      <p class="section-label">{t('process.label')}</p>
      <h2 class="section-title" id="process-title">{t('process.title')}</h2>
      <p class="section-subtitle">
        {t('process.subtitle')}
      </p>
    </div>

    <!-- Steps desktop strip -->
    <div class="process__steps" role="list">
      <!-- Animated progress line (desktop) -->
      <div class="process__line" aria-hidden="true">
        <div class="process__line-bg"></div>
        <div class="process__line-fill"></div>
      </div>

      {steps.map((step, i) => (
        <div class="process__step reveal" role="listitem" style={`transition-delay: ${i * 100}ms`} data-step={i}>
          <div class="process__step-num" aria-hidden="true">{step.number}</div>
          <div class="process__step-icon" aria-hidden="true">{step.icon}</div>
          <h3 class="process__step-title">{step.title}</h3>
          <p class="process__step-desc">{step.desc}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="process__cta reveal">
      <div class="process__cta-inner">
        <div class="process__cta-text">
          <h3 class="process__cta-title">{t('process.ctaTitle')}</h3>
          <p>{t('process.ctaDesc')}</p>
        </div>
        <a href={WA_URL} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          {t('process.ctaBtn')}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .process {
    background: var(--color-bg);
    overflow: hidden;
  }

  .process__header {
    text-align: center;
    margin-bottom: clamp(48px, 6vw, 80px);
  }

  .process__header .section-subtitle {
    margin: 0 auto;
  }

  /* Steps */
  .process__steps {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    margin-bottom: 72px;
    position: relative;
  }

  /* Animated progress line (desktop) */
  .process__line {
    position: absolute;
    top: 32px;
    left: calc(10% + 24px);
    right: calc(10% + 24px);
    height: 2px;
    z-index: 0;
  }

  .process__line-bg {
    position: absolute;
    inset: 0;
    background: var(--color-border);
    border-radius: 2px;
  }

  .process__line-fill {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-hover));
    border-radius: 2px;
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 1.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .process__steps.animated .process__line-fill {
    transform: scaleX(1);
  }

  .process__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 16px;
    position: relative;
    z-index: 1;
  }

  .process__step-num {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 4px;
    transition: color 0.3s ease;
  }

  .process__step-icon {
    font-size: 28px;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-alt);
    border: 1.5px solid var(--color-border);
    border-radius: 50%;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
    transition: background 0.4s ease, border-color 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.4s ease;
  }

  /* Completed state — triggered by JS */
  .process__step.step-done .process__step-icon {
    background: var(--color-bg-card);
    border-color: var(--color-accent);
    transform: scale(1.1);
    box-shadow: 0 0 0 4px rgba(196, 113, 79, 0.15);
  }

  .process__step.step-done .process__step-num {
    color: var(--color-accent);
  }

  .process__step:hover .process__step-icon {
    background: var(--color-bg-card);
    border-color: var(--color-accent);
    transform: scale(1.08);
  }

  .process__step-title {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .process__step-desc {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* CTA strip */
  .process__cta {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: clamp(28px, 4vw, 48px);
  }

  .process__cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .process__cta-title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 6px;
  }

  .process__cta-text p {
    font-size: 15px;
    color: var(--color-text-muted);
  }

  /* Mobile: vertical timeline */
  @media (max-width: 900px) {
    .process__line {
      display: none;
    }

    .process__steps {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
    }

    .process__step {
      flex-direction: row;
      text-align: left;
      align-items: flex-start;
      gap: 20px;
      padding: 0 0 32px 0;
      position: relative;
    }

    /* Vertical line bg track */
    .process__step:not(:last-child)::before {
      content: '';
      position: absolute;
      top: 64px;
      left: 31px;
      width: 2px;
      height: calc(100% - 32px);
      background: var(--color-border);
      border-radius: 2px;
    }

    /* Vertical line fill — animates with scaleY */
    .process__step:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 64px;
      left: 31px;
      width: 2px;
      height: calc(100% - 32px);
      background: linear-gradient(180deg, var(--color-accent), var(--color-accent-hover));
      border-radius: 2px;
      transform-origin: top center;
      transform: scaleY(0);
      transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Each step's line fills after the step is done */
    .process__step.step-done:not(:last-child)::after {
      transform: scaleY(1);
    }

    .process__step-icon {
      flex-shrink: 0;
    }

    .process__step-num {
      margin-bottom: 2px;
    }

    .process__cta-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .process__cta-inner .btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process__line-fill {
      transition: none !important;
      transform: scaleX(1) !important;
    }
    .process__step-icon {
      transition: none !important;
    }
  }
</style>

<script>
  const stepsEl = document.querySelector<HTMLElement>('.process__steps');
  if (stepsEl) {
    const steps = Array.from(stepsEl.querySelectorAll<HTMLElement>('[data-step]'));
    const STEP_DELAY = 360; // ms between each step completing

    const activate = () => {
      stepsEl.classList.add('animated');
      steps.forEach((step, i) => {
        setTimeout(() => step.classList.add('step-done'), i * STEP_DELAY + 200);
      });
    };

    // Skip animation if user prefers reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      stepsEl.classList.add('animated');
      steps.forEach(s => s.classList.add('step-done'));
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting) {
            activate();
            observer.disconnect();
          }
        },
        { threshold: 0.25 }
      );
      observer.observe(stepsEl);
    }
  }
</script>
