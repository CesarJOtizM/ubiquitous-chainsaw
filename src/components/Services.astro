---
import { useTranslations } from '../i18n/utils';

export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const WA_BASE = 'https://wa.me/573016584401?text=';

const services = [
  {
    icon: '🐾',
    title: t('services.s1.title'),
    desc: t('services.s1.desc'),
    features: [
      t('services.s1.f1'),
      t('services.s1.f2'),
      t('services.s1.f3'),
      t('services.s1.f4'),
    ],
    price: t('services.s1.price'),
    time: t('services.s1.time'),
    waMsg: t('services.s1.waMsg'),
    highlight: true,
  },
  {
    icon: '🌿',
    title: t('services.s2.title'),
    desc: t('services.s2.desc'),
    features: [
      t('services.s2.f1'),
      t('services.s2.f2'),
      t('services.s2.f3'),
      t('services.s2.f4'),
    ],
    price: t('services.s2.price'),
    time: t('services.s2.time'),
    waMsg: t('services.s2.waMsg'),
    highlight: false,
  },
  {
    icon: '📱',
    title: t('services.s3.title'),
    desc: t('services.s3.desc'),
    features: [
      t('services.s3.f1'),
      t('services.s3.f2'),
      t('services.s3.f3'),
      t('services.s3.f4'),
    ],
    price: t('services.s3.price'),
    time: t('services.s3.time'),
    waMsg: t('services.s3.waMsg'),
    highlight: false,
  },
];

const cuadros = [
  { size: '12×18 cm', price: '$120.000', special: false },
  { size: '20×25 cm', price: '$160.000', special: false },
  { size: '28×35 cm', price: '$220.000', special: false },
  { size: '40×50 cm', price: '$270.000', special: false },
  { size: t('services.cuadros.special'), price: '$150.000', special: true },
];
---

<section id="servicios" class="section services" aria-labelledby="services-title">
  <div class="container">
    <div class="services__header reveal">
      <p class="section-label">{t('services.label')}</p>
      <h2 class="section-title" id="services-title">{t('services.title')}</h2>
      <p class="section-subtitle">
        {t('services.subtitle')}
      </p>
    </div>

    <!-- Cards -->
    <div class="services__grid reveal-stagger">
      {services.map((s) => (
        <article class={`service-card reveal ${s.highlight ? 'service-card--highlight' : ''}`}>
          {s.highlight && (
            <div class="service-card__badge">{t('services.badge')}</div>
          )}
          <div class="service-card__icon" aria-hidden="true">{s.icon}</div>
          <h3 class="service-card__title">{s.title}</h3>
          <p class="service-card__desc">{s.desc}</p>
          <ul class="service-card__features" aria-label={`${lang === 'en' ? 'Includes' : 'Incluye'}: ${s.title}`}>
            {s.features.map((f) => (
              <li>
                <span class="service-card__check" aria-hidden="true">✓</span>
                {f}
              </li>
            ))}
          </ul>
          <div class="service-card__footer">
            <div class="service-card__meta">
              <span class="service-card__price">{s.price}</span>
              <span class="service-card__time">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
                {s.time}
              </span>
            </div>
            <a
              href={`${WA_BASE}${s.waMsg}`}
              class={`btn ${s.highlight ? 'btn-primary' : 'btn-outline'}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              {t('services.orderNow')}
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Pricing tabs -->
    <div class="services__pricing reveal">
      <h3 class="services__pricing-title">{t('services.pricingTitle')}</h3>

      <div class="pricing-tabs" role="tablist">
        <button class="pricing-tab is-active" data-tab="cuadros" role="tab" aria-selected="true">{t('services.tab.cuadros')}</button>
        <button class="pricing-tab" data-tab="bases" role="tab" aria-selected="false">{t('services.tab.bases')}</button>
        <button class="pricing-tab" data-tab="cases" role="tab" aria-selected="false">{t('services.tab.cases')}</button>
      </div>

      <!-- Cuadros panel -->
      <div class="pricing-panel is-active" data-panel="cuadros" role="tabpanel">
        <div class="table-wrap">
          <table class="pricing-table">
            <thead>
              <tr>
                <th scope="col">{t('services.cuadros.colSize')}</th>
                <th scope="col">{t('services.cuadros.colPrice')}</th>
              </tr>
            </thead>
            <tbody>
              {cuadros.map((row) => (
                <tr class={row.special ? 'row--special' : ''}>
                  <td>{row.size}</td>
                  <td>{row.price}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="panel-note">{t('services.cuadros.note')} {t('services.cuadros.addlPet')}.</p>
      </div>

      <!-- Bases panel -->
      <div class="pricing-panel" data-panel="bases" role="tabpanel" hidden>
        <div class="bases-grid">
          <div class="base-card">
            <span class="base-card__name">{t('services.bases.name1')}</span>
            <span class="base-card__size">{t('services.bases.size1')}</span>
            <span class="base-card__price">{t('services.bases.price1')}</span>
          </div>
          <div class="base-card">
            <span class="base-card__name">{t('services.bases.name2')}</span>
            <span class="base-card__size">{t('services.bases.size2')}</span>
            <span class="base-card__price">{t('services.bases.price2')}</span>
          </div>
        </div>
        <div class="panel-notes">
          <p class="panel-note">{t('services.bases.addlPet')}</p>
          <p class="panel-note panel-note--highlight">★ {t('services.bases.includes')}</p>
        </div>
      </div>

      <!-- Cases panel -->
      <div class="pricing-panel" data-panel="cases" role="tabpanel" hidden>
        <div class="cases-grid">
          <div class="case-card">
            <span class="case-card__name">{t('services.cases.type1')}</span>
            <span class="case-card__price">{t('services.cases.price1')}</span>
            <span class="case-card__desc">{t('services.cases.desc1')}</span>
          </div>
          <div class="case-card">
            <span class="case-card__name">{t('services.cases.type2')}</span>
            <span class="case-card__price">{t('services.cases.price2')}</span>
            <span class="case-card__desc">{t('services.cases.desc2')}</span>
          </div>
          <div class="case-card">
            <span class="case-card__name">{t('services.cases.type3')}</span>
            <span class="case-card__price">{t('services.cases.price3')}</span>
            <span class="case-card__desc">{t('services.cases.desc3')}</span>
          </div>
          <div class="case-card case-card--highlight">
            <span class="case-card__name">{t('services.cases.type4')}</span>
            <span class="case-card__price">{t('services.cases.price4')}</span>
            <span class="case-card__desc">{t('services.cases.desc4')}</span>
          </div>
        </div>
        <p class="panel-note">{t('services.cases.addlPet')}</p>
      </div>

      <p class="services__table-note">
        {t('services.tableNote')}{' '}
        <a href={`${WA_BASE}${t('services.tableNoteMsg')}`} target="_blank" rel="noopener noreferrer">
          {t('services.tableNoteLink')}
        </a>.
      </p>
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--color-bg-alt);
  }

  .services__header {
    text-align: center;
    margin-bottom: clamp(48px, 6vw, 72px);
  }

  .services__header .section-subtitle {
    margin: 0 auto;
    text-align: center;
  }

  /* Grid */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 64px;
  }

  /* Card */
  .service-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(44, 44, 44, 0.1);
  }

  .service-card--highlight {
    border-color: var(--color-accent);
    background: var(--color-bg);
  }

  .service-card--highlight::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-accent);
    border-radius: 12px 12px 0 0;
  }

  .service-card__badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent);
    color: #fff;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .service-card__icon {
    font-size: 36px;
    margin-bottom: 16px;
  }

  .service-card__title {
    font-family: var(--font-heading);
    font-size: clamp(22px, 2vw, 28px);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 12px;
  }

  .service-card__desc {
    font-size: 15px;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 24px;
  }

  .service-card__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 28px;
    flex: 1;
  }

  .service-card__features li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--color-text);
  }

  .service-card__check {
    color: var(--color-sage);
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .service-card__footer {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .service-card__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .service-card__price {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    color: var(--color-accent);
  }

  .service-card__time {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--color-text-muted);
  }

  /* Pricing tabs */
  .services__pricing {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: clamp(28px, 4vw, 48px);
  }

  .services__pricing-title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 24px;
  }

  .pricing-tabs {
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--color-border);
    margin-bottom: 28px;
  }

  .pricing-tab {
    background: none;
    border: none;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    cursor: pointer;
    position: relative;
    transition: color 0.2s ease;
  }

  .pricing-tab::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transition: transform 0.2s ease;
  }

  .pricing-tab:hover {
    color: var(--color-text);
  }

  .pricing-tab.is-active {
    color: var(--color-accent);
  }

  .pricing-tab.is-active::after {
    transform: scaleX(1);
  }

  .pricing-panel {
    animation: fadeIn 0.2s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Cuadros table */
  .table-wrap {
    overflow-x: auto;
    margin-bottom: 16px;
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 15px;
  }

  .pricing-table th {
    text-align: left;
    padding: 12px 20px;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-border);
  }

  .pricing-table th:first-child { border-radius: 8px 0 0 0; }
  .pricing-table th:last-child  { border-radius: 0 8px 0 0; }

  .pricing-table td {
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .pricing-table td:first-child { font-weight: 500; }
  .pricing-table tbody tr:last-child td { border-bottom: none; }
  .pricing-table tbody tr:hover td { background: var(--color-bg-alt); }

  .pricing-table tr.row--special td {
    color: var(--color-accent);
    font-weight: 500;
  }

  /* Bases cards */
  .bases-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 20px;
  }

  .base-card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: border-color 0.2s ease;
  }

  .base-card:hover {
    border-color: var(--color-accent);
  }

  .base-card__name {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 500;
    color: var(--color-text);
  }

  .base-card__size {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .base-card__price {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 500;
    color: var(--color-accent);
    margin-top: 8px;
  }

  /* Cases cards */
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 20px;
  }

  .case-card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: border-color 0.2s ease;
  }

  .case-card:hover {
    border-color: var(--color-accent);
  }

  .case-card--highlight {
    border-color: var(--color-accent);
    background: var(--color-bg-alt);
  }

  .case-card__name {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-text);
  }

  .case-card__price {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    color: var(--color-accent);
    margin-top: 4px;
  }

  .case-card__desc {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Shared panel notes */
  .panel-notes {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .panel-note {
    font-size: 13px;
    color: var(--color-text-muted);
    margin-bottom: 16px;
  }

  .panel-note--highlight {
    color: var(--color-sage);
    font-weight: 500;
  }

  .services__table-note {
    font-size: 13px;
    color: var(--color-text-muted);
    margin-top: 20px;
  }

  .services__table-note a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .bases-grid {
      grid-template-columns: 1fr;
    }

    .cases-grid {
      grid-template-columns: 1fr;
    }

    .pricing-tab {
      padding: 10px 14px;
      font-size: 13px;
    }
  }

  @media (max-width: 1024px) {
    .services__grid {
      grid-template-columns: 1fr;
      max-width: 540px;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 640px) {
    .services__grid {
      max-width: 100%;
    }
  }
</style>

<script>
  function initPricingTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.pricing-tab');
    const panels = document.querySelectorAll<HTMLElement>('.pricing-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;

        tabs.forEach((t) => {
          t.classList.remove('is-active');
          t.setAttribute('aria-selected', 'false');
        });
        panels.forEach((p) => {
          p.classList.remove('is-active');
          p.hidden = true;
        });

        tab.classList.add('is-active');
        tab.setAttribute('aria-selected', 'true');
        const panel = document.querySelector<HTMLElement>(`[data-panel="${target}"]`);
        if (panel) {
          panel.classList.add('is-active');
          panel.hidden = false;
        }
      });
    });
  }

  initPricingTabs();
  document.addEventListener('astro:after-swap', initPricingTabs);
</script>
