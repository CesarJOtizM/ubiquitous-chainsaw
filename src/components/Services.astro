---
import { useTranslations } from '../i18n/utils';

export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const WA_BASE = 'https://wa.me/573016584401?text=';

const services = [
  {
    icon: '🐾',
    title: t('services.s1.title'),
    desc: t('services.s1.desc'),
    features: [
      t('services.s1.f1'),
      t('services.s1.f2'),
      t('services.s1.f3'),
      t('services.s1.f4'),
    ],
    price: t('services.s1.price'),
    time: t('services.s1.time'),
    waMsg: t('services.s1.waMsg'),
    highlight: true,
  },
  {
    icon: '🌿',
    title: t('services.s2.title'),
    desc: t('services.s2.desc'),
    features: [
      t('services.s2.f1'),
      t('services.s2.f2'),
      t('services.s2.f3'),
      t('services.s2.f4'),
    ],
    price: t('services.s2.price'),
    time: t('services.s2.time'),
    waMsg: t('services.s2.waMsg'),
    highlight: false,
  },
  {
    icon: '📱',
    title: t('services.s3.title'),
    desc: t('services.s3.desc'),
    features: [
      t('services.s3.f1'),
      t('services.s3.f2'),
      t('services.s3.f3'),
      t('services.s3.f4'),
    ],
    price: t('services.s3.price'),
    time: t('services.s3.time'),
    waMsg: t('services.s3.waMsg'),
    highlight: false,
  },
];

const pricing = [
  { size: '20×20 cm', one: '$150.000', two: '$220.000' },
  { size: '30×30 cm', one: '$220.000', two: '$320.000' },
  { size: '40×40 cm', one: '$320.000', two: t('services.price.inquire') },
];
---

<section id="servicios" class="section services" aria-labelledby="services-title">
  <div class="container">
    <div class="services__header reveal">
      <p class="section-label">{t('services.label')}</p>
      <h2 class="section-title" id="services-title">{t('services.title')}</h2>
      <p class="section-subtitle">
        {t('services.subtitle')}
      </p>
    </div>

    <!-- Cards -->
    <div class="services__grid reveal-stagger">
      {services.map((s) => (
        <article class={`service-card reveal ${s.highlight ? 'service-card--highlight' : ''}`}>
          {s.highlight && (
            <div class="service-card__badge">{t('services.badge')}</div>
          )}
          <div class="service-card__icon" aria-hidden="true">{s.icon}</div>
          <h3 class="service-card__title">{s.title}</h3>
          <p class="service-card__desc">{s.desc}</p>
          <ul class="service-card__features" aria-label={`${lang === 'en' ? 'Includes' : 'Incluye'}: ${s.title}`}>
            {s.features.map((f) => (
              <li>
                <span class="service-card__check" aria-hidden="true">✓</span>
                {f}
              </li>
            ))}
          </ul>
          <div class="service-card__footer">
            <div class="service-card__meta">
              <span class="service-card__price">{s.price}</span>
              <span class="service-card__time">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
                {s.time}
              </span>
            </div>
            <a
              href={`${WA_BASE}${s.waMsg}`}
              class={`btn ${s.highlight ? 'btn-primary' : 'btn-outline'}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              {t('services.orderNow')}
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Pricing table -->
    <div class="services__table reveal">
      <h3 class="services__table-title">{t('services.tableTitle')}</h3>
      <div class="table-wrap">
        <table class="pricing-table" aria-label={t('services.tableAriaLabel')}>
          <thead>
            <tr>
              <th scope="col">{t('services.colSize')}</th>
              <th scope="col">{t('services.col1Pet')}</th>
              <th scope="col">{t('services.col2Pets')}</th>
            </tr>
          </thead>
          <tbody>
            {pricing.map((row) => (
              <tr>
                <td>{row.size}</td>
                <td>{row.one}</td>
                <td>{row.two}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="services__table-note">
        {t('services.tableNote')}{' '}
        <a href={`${WA_BASE}${t('services.tableNoteMsg')}`} target="_blank" rel="noopener noreferrer">
          {t('services.tableNoteLink')}
        </a>.
      </p>
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--color-bg-alt);
  }

  .services__header {
    text-align: center;
    margin-bottom: clamp(48px, 6vw, 72px);
  }

  .services__header .section-subtitle {
    margin: 0 auto;
    text-align: center;
  }

  /* Grid */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 64px;
  }

  /* Card */
  .service-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(44, 44, 44, 0.1);
  }

  .service-card--highlight {
    border-color: var(--color-accent);
    background: var(--color-bg);
  }

  .service-card--highlight::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-accent);
    border-radius: 12px 12px 0 0;
  }

  .service-card__badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent);
    color: #fff;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .service-card__icon {
    font-size: 36px;
    margin-bottom: 16px;
  }

  .service-card__title {
    font-family: var(--font-heading);
    font-size: clamp(22px, 2vw, 28px);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 12px;
  }

  .service-card__desc {
    font-size: 15px;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 24px;
  }

  .service-card__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 28px;
    flex: 1;
  }

  .service-card__features li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--color-text);
  }

  .service-card__check {
    color: var(--color-sage);
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .service-card__footer {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .service-card__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .service-card__price {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    color: var(--color-accent);
  }

  .service-card__time {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--color-text-muted);
  }

  /* Pricing table */
  .services__table {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: clamp(28px, 4vw, 48px);
  }

  .services__table-title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 24px;
  }

  .table-wrap {
    overflow-x: auto;
    margin-bottom: 16px;
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 15px;
  }

  .pricing-table th {
    text-align: left;
    padding: 12px 20px;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-border);
  }

  .pricing-table th:first-child {
    border-radius: 8px 0 0 0;
  }

  .pricing-table th:last-child {
    border-radius: 0 8px 0 0;
  }

  .pricing-table td {
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .pricing-table td:first-child {
    font-weight: 500;
  }

  .pricing-table tbody tr:last-child td {
    border-bottom: none;
  }

  .pricing-table tbody tr:hover td {
    background: var(--color-bg-alt);
  }

  .services__table-note {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .services__table-note a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  @media (max-width: 1024px) {
    .services__grid {
      grid-template-columns: 1fr;
      max-width: 540px;
      margin-left: auto;
      margin-right: auto;
    }
  }

  @media (max-width: 640px) {
    .services__grid {
      max-width: 100%;
    }
  }
</style>
