---
import { useTranslations } from '../i18n/utils';

export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const testimonials = [
  {
    id: 1,
    stars: 5,
    quote: t('testimonials.t1.quote'),
    author: '@ybetancour',
    date: lang === 'en' ? 'Mar 4, 2026' : '4 mar. 2026',
    location: '',
    pet: '',
    image: '/images/bases-acrilicas/5.jpeg',
    gradient: '',
    instagramUrl: 'https://www.instagram.com/reel/DVeDl6JjbD4?comment_id=18083135780611556&open_comments=true',
  },
  {
    id: 2,
    stars: 5,
    quote: t('testimonials.t2.quote'),
    author: '@paupalamen5',
    date: lang === 'en' ? 'Mar 6, 2026' : '6 mar. 2026',
    location: '',
    pet: '',
    image: '/images/bases-acrilicas/3.jpeg',
    gradient: '',
    instagramUrl: 'https://www.instagram.com/reel/DVjXXPTkeee?comment_id=17865277986598754&open_comments=true',
  },
  {
    id: 3,
    stars: 5,
    quote: t('testimonials.t3.quote'),
    author: '@sannicolasx7',
    date: lang === 'en' ? 'Jan 30, 2026' : '30 ene. 2026',
    location: '',
    pet: '',
    image: '/images/case-anime/20251215_144918.jpg',
    gradient: '',
    instagramUrl: 'https://www.instagram.com/reel/DUJk7O9ka7x?comment_id=18023863964796383&open_comments=true',
  },
  {
    id: 4,
    stars: 5,
    quote: t('testimonials.t4.quote'),
    author: 'Maribel',
    date: lang === 'en' ? 'Mar 5, 2026' : '5 mar. 2026',
    location: '',
    pet: '',
    image: '/images/bases-acrilicas/14.jpeg',
    gradient: '',
    instagramUrl: 'https://www.instagram.com/s/aGlnaGxpZ2h0OjE4MDA2NDA1MDAyMzQ3NTgx?story_media_id=3836768790273448818_55473517501',
  },
];
---

<section id="testimonios" class="section testimonials" aria-labelledby="testimonials-title">
  <svg class="section-deco" viewBox="0 0 1440 700" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M -20 115 Q 400 210 800 110 T 1460 155" stroke="#C9A227" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.4" fill="none"/>
    <path d="M 980 530 Q 1200 468 1460 510" stroke="#C9A227" stroke-width="1" stroke-dasharray="4 6" opacity="0.26" fill="none"/>
  </svg>
  <div class="brush-deco brush-deco--pale brush-d" aria-hidden="true" style="width:640px;height:155px;top:-15px;left:-70px;opacity:0.18;transform:rotate(-5deg)"></div>
  <div class="brush-deco brush-deco--medium brush-f" aria-hidden="true" style="width:460px;height:115px;bottom:50px;right:-50px;opacity:0.13;transform:rotate(8deg)"></div>
  <div class="brush-deco brush-deco--light brush-g" aria-hidden="true" style="width:300px;height:75px;top:40%;right:12%;opacity:0.09;transform:rotate(-9deg)"></div>
  <div class="container">
    <div class="testimonials__header reveal">
      <p class="section-label">{t('testimonials.label')}</p>
      <h2 class="section-title" id="testimonials-title">{t('testimonials.title')}</h2>
      <div class="testimonials__rating reveal">
        <div class="testimonials__stars" aria-label={t('testimonials.ratingLabel')}>
          ⭐⭐⭐⭐⭐
        </div>
        <span>{t('testimonials.ratingText')}</span>
      </div>
    </div>

    <!-- Desktop grid / Mobile scroll -->
    <div class="testimonials__grid" role="list">
      {testimonials.map((testimonial, i) => (
        <article
          class="testimonial-card reveal"
          role="listitem"
          style={`transition-delay: ${i * 120}ms`}
          aria-label={`${lang === 'en' ? 'Testimonial from' : 'Testimonio de'} ${testimonial.author}`}
        >
          <!-- Artwork -->
          {testimonial.image ? (
            <div class="testimonial-card__artwork testimonial-card__artwork--photo" aria-hidden="true">
              <img
                src={testimonial.image}
                alt={`Cuadro personalizado de mascota`}
                class="testimonial-card__artwork-img"
                loading="lazy"
              />
              {testimonial.instagramUrl && (
                <a
                  href={testimonial.instagramUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="testimonial-card__ig-badge"
                  aria-label="Ver comentario en Instagram"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                  Ver en Instagram
                </a>
              )}
            </div>
          ) : (
            <div
              class="testimonial-card__artwork"
              style={`background: ${testimonial.gradient};`}
              aria-hidden="true"
            >
              <span class="testimonial-card__artwork-icon">🐾</span>
              <span class="testimonial-card__artwork-label">{testimonial.pet}</span>
            </div>
          )}

          <!-- Stars -->
          <div class="testimonial-card__stars" aria-label={`${testimonial.stars} ${lang === 'en' ? 'out of 5 stars' : 'de 5 estrellas'}`}>
            {'⭐'.repeat(testimonial.stars)}
          </div>

          <!-- Quote -->
          <blockquote class="testimonial-card__quote">
            <p>"{testimonial.quote}"</p>
          </blockquote>

          <!-- Author -->
          <footer class="testimonial-card__author">
            <div class="testimonial-card__avatar" aria-hidden="true">
              {testimonial.author.startsWith('@') ? '📸' : testimonial.author.charAt(0)}
            </div>
            <div>
              <strong>— {testimonial.author}</strong>
              <span class="testimonial-card__date">· {testimonial.date}</span>
            </div>
          </footer>
        </article>
      ))}
    </div>

    <!-- Google reviews note -->
    <div class="testimonials__footer reveal">
      <p>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        {t('testimonials.footerText')}<a href="https://www.instagram.com/sac_artx" target="_blank" rel="noopener noreferrer">{t('testimonials.footerLink')}</a>
      </p>
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: linear-gradient(to bottom, transparent 0px, var(--color-bg) 100px, var(--color-bg) calc(100% - 100px), transparent 100%);
  }

  .testimonials__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .testimonials__rating {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 16px;
    font-size: 14px;
    color: var(--color-text-muted);
  }

  .testimonials__stars {
    font-size: 18px;
    letter-spacing: 2px;
  }

  /* Grid */
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }

  /* Card */
  .testimonial-card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(44, 44, 44, 0.08);
  }

  .testimonial-card__artwork {
    height: 160px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    position: relative;
    overflow: hidden;
  }

  .testimonial-card__artwork--photo {
    height: 240px;
  }

  .testimonial-card__artwork-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .testimonial-card__ig-badge {
    position: absolute;
    bottom: 10px;
    right: 10px;
    display: flex;
    align-items: center;
    gap: 5px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(6px);
    color: #fff;
    font-size: 11px;
    font-weight: 500;
    padding: 5px 10px;
    border-radius: 20px;
    text-decoration: none;
    transition: background 0.2s ease;
    letter-spacing: 0.02em;
  }

  .testimonial-card__ig-badge:hover {
    background: rgba(193, 53, 132, 0.8);
  }

  .testimonial-card__artwork-icon {
    font-size: 40px;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.1));
  }

  .testimonial-card__artwork-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: rgba(255,255,255,0.6);
    padding: 2px 10px;
    border-radius: 20px;
  }

  .testimonial-card__stars {
    font-size: 14px;
    padding: 20px 24px 0;
    letter-spacing: 2px;
  }

  .testimonial-card__quote {
    padding: 12px 24px;
    flex: 1;
  }

  .testimonial-card__quote p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text);
    font-style: italic;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px 24px;
    border-top: 1px solid var(--color-border);
    font-size: 14px;
    color: var(--color-text-muted);
  }

  .testimonial-card__author strong {
    color: var(--color-text);
    font-weight: 500;
    font-style: normal;
  }

  .testimonial-card__date {
    color: var(--color-text-muted);
    font-size: 13px;
  }

  .testimonial-card__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 14px;
    flex-shrink: 0;
  }

  /* Footer */
  .testimonials__footer {
    text-align: center;
    font-size: 14px;
    color: var(--color-text-muted);
  }

  .testimonials__footer p {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .testimonials__footer a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
