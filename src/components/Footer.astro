---
import { useTranslations } from '../i18n/utils';

export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const WA_URL = `https://wa.me/573016584401?text=${t('contact.waMsg')}`;
const IG_URL = 'https://www.instagram.com/sac_artx';
const TK_URL = 'https://www.tiktok.com/@sac_artx';
const FB_URL = 'https://www.facebook.com/share/1ApXQ8V8SK/';

const year = new Date().getFullYear();

const links = [
  { href: '#servicios', label: t('footer.nav.services') },
  { href: '#proceso', label: t('footer.nav.process') },
  { href: '#galeria', label: t('footer.nav.gallery') },
  { href: '#contacto', label: t('footer.nav.contact') },
];
---

<footer class="footer" role="contentinfo">
  <div class="footer__inner container">
    <!-- Top section -->
    <div class="footer__top">
      <!-- Brand -->
      <div class="footer__brand">
        <a href={lang === 'en' ? '/en/' : '/'} class="footer__logo" aria-label={t('footer.logoAriaLabel')}>
          Sac_Artx
        </a>
        <p class="footer__tagline">{t('footer.tagline')}</p>
        <p class="footer__desc">
          {t('footer.desc')}
        </p>
      </div>

      <!-- Nav -->
      <nav class="footer__nav" aria-label={t('footer.navAriaLabel')}>
        <p class="footer__nav-title">{t('footer.navTitle')}</p>
        {links.map((link) => (
          <a href={link.href} class="footer__nav-link">{link.label}</a>
        ))}
      </nav>

      <!-- Contact -->
      <div class="footer__contact">
        <p class="footer__nav-title">{t('footer.contactTitle')}</p>
        <a
          href={WA_URL}
          class="footer__contact-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${t('footer.waAriaLabel')}: +57 301 6584401`}
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          +57 301 6584401
        </a>
        <a
          href={IG_URL}
          class="footer__contact-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t('footer.igAriaLabel')}
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
          </svg>
          @sac_artx
        </a>
        <a
          href={TK_URL}
          class="footer__contact-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="TikTok Sac_Artx"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05A6.34 6.34 0 003.15 15.3a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.16 8.16 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/>
          </svg>
          @sac_artx
        </a>
        <a
          href={FB_URL}
          class="footer__contact-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook Sac_Artx"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          Sac_Artx
        </a>
        <div class="footer__social">
          <a
            href={IG_URL}
            class="footer__social-btn"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t('footer.igSocialAriaLabel')}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <a
            href={WA_URL}
            class="footer__social-btn footer__social-btn--wa"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t('footer.waSocialAriaLabel')}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
          </a>
          <a
            href={TK_URL}
            class="footer__social-btn footer__social-btn--tk"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="TikTok Sac_Artx"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05A6.34 6.34 0 003.15 15.3a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.16 8.16 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/>
            </svg>
          </a>
          <a
            href={FB_URL}
            class="footer__social-btn footer__social-btn--fb"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook Sac_Artx"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p class="footer__copy">
        &copy; {year} Sac_Artx &middot; {t('footer.rights')}
      </p>
      <p class="footer__made">
        {t('footer.madeWith')}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-text);
    color: rgba(255,255,255,0.75);
  }

  .footer__inner {
    padding-top: clamp(48px, 6vw, 80px);
    padding-bottom: clamp(24px, 4vw, 40px);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: clamp(32px, 5vw, 72px);
    margin-bottom: clamp(40px, 5vw, 64px);
    padding-bottom: clamp(40px, 5vw, 64px);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  /* Brand */
  .footer__logo {
    font-family: var(--font-logo);
    font-size: 32px;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: #fff;
    text-decoration: none;
    display: block;
    margin-bottom: 8px;
    transition: color 0.2s;
  }

  .footer__logo:hover {
    color: var(--color-accent);
  }

  .footer__tagline {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #D48CE0;
    margin-bottom: 16px;
  }

  .footer__desc {
    font-size: 14px;
    line-height: 1.7;
    max-width: 300px;
  }

  /* Nav */
  .footer__nav-title {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin-bottom: 16px;
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__nav-link {
    font-size: 15px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer__nav-link:hover {
    color: #fff;
  }

  /* Contact */
  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__contact-link {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer__contact-link:hover {
    color: #fff;
  }

  .footer__social {
    display: flex;
    gap: 10px;
    margin-top: 8px;
  }

  .footer__social-btn {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .footer__social-btn:hover {
    background: rgba(255,255,255,0.15);
    color: #fff;
  }

  .footer__social-btn--wa:hover {
    background: var(--color-whatsapp);
    border-color: var(--color-whatsapp);
    color: #fff;
  }

  .footer__social-btn--tk:hover {
    background: #000;
    border-color: #000;
    color: #fff;
  }

  .footer__social-btn--fb:hover {
    background: #1877f2;
    border-color: #1877f2;
    color: #fff;
  }

  /* Bottom */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  .footer__copy,
  .footer__made {
    font-size: 13px;
    color: rgba(255,255,255,0.65);
  }

  @media (max-width: 900px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 540px) {
    .footer__top {
      grid-template-columns: 1fr;
    }

    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
