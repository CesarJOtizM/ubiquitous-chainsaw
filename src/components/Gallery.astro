// Fisher-Yates shuffle — mezcla en build time para que "Todos" muestre variedad
function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
const shuffledItems = shuffle(galleryItems);

const filters = [
