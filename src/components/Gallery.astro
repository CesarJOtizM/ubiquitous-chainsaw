---
import { useTranslations } from '../i18n/utils';

export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const acrylic = (size: string) => `${t('gallery.technique')} ${size}`;
const digital = () => t('gallery.techniqueDigital');

const galleryItems = [
  {
    id: 1,
    category: 'mascotas',
    title: t('gallery.item1.title'),
    technique: acrylic('30×30cm'),
    gradient: 'linear-gradient(135deg, #C4714F55, #8A9E8C55)',
    height: 260,
    w: 900,
    h: 900,
  },
  {
    id: 2,
    category: 'mascotas',
    title: t('gallery.item2.title'),
    technique: acrylic('20×20cm'),
    gradient: 'linear-gradient(135deg, #8A9E8C44, #C4714F44)',
    height: 200,
    w: 800,
    h: 800,
  },
  {
    id: 3,
    category: 'paisajes',
    title: t('gallery.item3.title'),
    technique: acrylic('40×30cm'),
    gradient: 'linear-gradient(135deg, #D4845F55, #8A9E8C33)',
    height: 300,
    w: 1200,
    h: 900,
  },
  {
    id: 4,
    category: 'mascotas',
    title: t('gallery.item4.title'),
    technique: acrylic('30×30cm'),
    gradient: 'linear-gradient(135deg, #EDE8DF, #C4714F33)',
    height: 220,
    w: 900,
    h: 900,
  },
  {
    id: 5,
    category: 'fundas',
    title: t('gallery.item5.title'),
    technique: digital(),
    gradient: 'linear-gradient(135deg, #2C2C2C22, #C4714F55)',
    height: 260,
    w: 600,
    h: 800,
  },
  {
    id: 6,
    category: 'mascotas',
    title: t('gallery.item6.title'),
    technique: acrylic('40×40cm'),
    gradient: 'linear-gradient(135deg, #C4714F33, #D4845F55)',
    height: 300,
    w: 900,
    h: 900,
  },
  {
    id: 7,
    category: 'paisajes',
    title: t('gallery.item7.title'),
    technique: acrylic('50×40cm'),
    gradient: 'linear-gradient(135deg, #D4845F44, #8A9E8C44)',
    height: 200,
    w: 1200,
    h: 900,
  },
  {
    id: 8,
    category: 'mascotas',
    title: t('gallery.item8.title'),
    technique: acrylic('20×20cm'),
    gradient: 'linear-gradient(135deg, #EDE8DF, #8A9E8C44)',
    height: 260,
    w: 800,
    h: 800,
  },
  {
    id: 9,
    category: 'fundas',
    title: t('gallery.item9.title'),
    technique: digital(),
    gradient: 'linear-gradient(135deg, #8A9E8C33, #C4714F44)',
    height: 220,
    w: 600,
    h: 800,
  },
  {
    id: 10,
    category: 'mascotas',
    title: t('gallery.item10.title'),
    technique: acrylic('30×30cm'),
    gradient: 'linear-gradient(135deg, #C4714F44, #EDE8DF)',
    height: 200,
    w: 900,
    h: 900,
  },
  {
    id: 11,
