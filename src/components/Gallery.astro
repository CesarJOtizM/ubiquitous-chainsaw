---

<section id="galeria" class="section gallery" aria-labelledby="gallery-title">
  <div class="container">
    <div class="gallery__header reveal">
      <p class="section-label">{t('gallery.label')}</p>
      <h2 class="section-title" id="gallery-title">{t('gallery.title')}</h2>
      <p class="section-subtitle">{t('gallery.subtitle')}</p>
    </div>

    <!-- Filters -->
    <div class="gallery__filters reveal" role="group" aria-label={t('gallery.filtersAriaLabel')}>
      {filters.map((f) => (
        <button
          class={`gallery__filter-btn ${f.key === 'all' ? 'active' : ''}`}
          data-filter={f.key}
          aria-pressed={f.key === 'all' ? 'true' : 'false'}
        >
          {f.label}
        </button>
      ))}
    </div>

    <!-- Lightbox -->
    <div
      id="gallery-lightbox"
      class="lightbox"
      role="dialog"
      aria-modal="true"
      aria-label={lang === 'en' ? 'Artwork viewer' : 'Visor de obra'}
      hidden
    >
      <div class="lightbox__backdrop"></div>

      <button class="lightbox__close" aria-label={lang === 'en' ? 'Close' : 'Cerrar'}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <div class="lightbox__shell">
        <button class="lightbox__nav lightbox__prev" aria-label={lang === 'en' ? 'Previous artwork' : 'Obra anterior'}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>

        <div class="lightbox__content">
          <div class="lightbox__media" id="lightbox-media"></div>
          <div class="lightbox__meta">
            <span class="lightbox__cat" id="lightbox-cat"></span>
            <span class="lightbox__tech" id="lightbox-tech"></span>
          </div>
          <div class="lightbox__counter" id="lightbox-counter"></div>
        </div>

        <button class="lightbox__nav lightbox__next" aria-label={lang === 'en' ? 'Next artwork' : 'Siguiente obra'}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Masonry grid -->
    <div id="pswp-gallery" class="gallery__grid" aria-label={t('gallery.ariaLabel')}>
      {shuffledItems.map((item) => (
        <a
          href={item.src}
          class="gallery-card"
          data-category={item.category}
          aria-label={`${lang === 'en' ? 'View artwork' : 'Ver obra'}: ${categoryMeta[item.category].label}`}
          role="button"
        >
          <div class="gallery-card__img">
            <img
              src={item.src}
              alt={categoryMeta[item.category].label}
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="gallery-card__overlay" aria-hidden="true">
            <div class="gallery-card__info">
              <span class="gallery-card__cat">{categoryMeta[item.category].label}</span>
              <span class="gallery-card__tech">{categoryMeta[item.category].technique}</span>
              <span class="gallery-card__cta">{t('gallery.viewWork')}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Load more -->
    <div class="gallery__load-more" id="gallery-load-more">
      <button class="gallery__load-more-btn" id="load-more-btn">
        {t('gallery.loadMore')}
      </button>
    </div>
  </div>
</section>

<style>
  .gallery {
    background: var(--color-bg-alt);
  }

  .gallery__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .gallery__header .section-subtitle {
    margin: 0 auto;
  }

  /* Filters */
  .gallery__filters {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .gallery__filter-btn {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 20px;
    border-radius: 40px;
    border: 1.5px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .gallery__filter-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .gallery__filter-btn.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  /* Masonry grid using CSS columns */
  .gallery__grid {
    columns: 3;
    column-gap: 16px;
  }

  /* Cards */
  .gallery-card {
    display: block;
    break-inside: avoid;
    margin-bottom: 16px;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .gallery-card.hidden {
    display: none;
  }

  .gallery-card:hover {
    transform: translateY(-2px);
  }

  .gallery-card__img {
    width: 100%;
    display: block;
    position: relative;
    overflow: hidden;
  }

  .gallery-card__img img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.4s ease;
  }

  .gallery-card:hover .gallery-card__img img {
    transform: scale(1.04);
  }

  .gallery-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 30%, rgba(44, 44, 44, 0.85) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: flex-end;
  }

  .gallery-card:hover .gallery-card__overlay {
    opacity: 1;
  }

  .gallery-card__info {
    padding: 20px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .gallery-card__cat {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-sage);
  }

  .gallery-card__tech {
    font-size: 12px;
    color: rgba(255,255,255,0.7);
  }

  .gallery-card__cta {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-accent-hover);
    margin-top: 4px;
  }

  /* Load more */
  .gallery__load-more {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }

  .gallery__load-more-btn {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    padding: 12px 36px;
    border-radius: 40px;
    border: 1.5px solid var(--color-accent);
    background: transparent;
    color: var(--color-accent);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .gallery__load-more-btn:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .gallery__load-more.hidden {
    display: none;
  }

  @media (max-width: 900px) {
    .gallery__grid { columns: 2; }
  }

  @media (max-width: 540px) {
    .gallery__grid { columns: 1; }
  }

  /* ─── Lightbox ─── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] { display: none; }

  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(20, 16, 14, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .lightbox__shell {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    max-width: 1100px;
    padding: 0 24px;
    animation: lb-in 0.3s cubic-bezier(0.34, 1.2, 0.64, 1);
  }

  @keyframes lb-in {
    from { opacity: 0; transform: scale(0.93); }
    to   { opacity: 1; transform: scale(1); }
  }

  .lightbox__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    min-width: 0;
  }

  .lightbox__media {
    width: 100%;
    max-height: 72vh;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox__media img {
    max-width: 100%;
    max-height: 72vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 8px;
  }

  .lightbox__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-align: center;
  }

  .lightbox__cat {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-sage);
  }

  .lightbox__tech {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
  }

  .lightbox__counter {
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.06em;
  }

  .lightbox__close {
    position: absolute;
    top: 20px;
    right: 24px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.08);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    z-index: 2;
  }

  .lightbox__close:hover {
    background: rgba(255,255,255,0.18);
    border-color: rgba(255,255,255,0.4);
    transform: scale(1.08);
  }

  .lightbox__nav {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.06);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, border-color 0.2s;
  }

  .lightbox__nav:hover {
    background: rgba(255,255,255,0.16);
    border-color: rgba(255,255,255,0.4);
  }

  .lightbox__nav:disabled {
    opacity: 0.2;
    cursor: default;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .lightbox__shell { padding: 0 12px; gap: 8px; }
    .lightbox__nav   { width: 36px; height: 36px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox__shell { animation: none; }
  }
</style>

<script>
  const INITIAL_COUNT = 9;
  const PER_PAGE      = 6;

  const allCards   = Array.from(document.querySelectorAll<HTMLElement>('.gallery-card'));
  const loadMoreWrap = document.getElementById('gallery-load-more')!;
  const loadMoreBtn  = document.getElementById('load-more-btn')!;

  let currentFilter = 'all';
  let visibleCount  = INITIAL_COUNT;

  // ── Visibility engine ──────────────────────────────────────────────────────
  function matchingCards(): HTMLElement[] {
    return allCards.filter(c =>
      currentFilter === 'all' || c.dataset.category === currentFilter
    );
  }

  function applyVisibility(animate = false) {
    const matching = matchingCards();

    allCards.forEach(card => {
      card.classList.add('hidden');
      card.style.opacity   = '';
      card.style.transform = '';
      card.style.transition = '';
    });

    matching.slice(0, visibleCount).forEach((card, i) => {
      card.classList.remove('hidden');
      if (animate) {
        card.style.opacity   = '0';
        card.style.transform = 'scale(0.96)';
        setTimeout(() => {
          card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
          card.style.opacity    = '1';
          card.style.transform  = 'scale(1)';
        }, i * 30);
      }
    });

    loadMoreWrap.classList.toggle('hidden', matching.length <= visibleCount);
  }

  // Init — show first batch without animation
  applyVisibility(false);

  // ── Filters ────────────────────────────────────────────────────────────────
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.gallery__filter-btn');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');

      currentFilter = btn.dataset.filter ?? 'all';
      visibleCount  = INITIAL_COUNT;
      applyVisibility(true);
    });
  });

  // ── Load more ──────────────────────────────────────────────────────────────
  loadMoreBtn.addEventListener('click', () => {
    const prevCount = visibleCount;
    visibleCount += PER_PAGE;

    const matching = matchingCards();
    matching.slice(prevCount, visibleCount).forEach((card, i) => {
      card.classList.remove('hidden');
      card.style.opacity   = '0';
      card.style.transform = 'scale(0.96)';
      setTimeout(() => {
        card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
        card.style.opacity    = '1';
        card.style.transform  = 'scale(1)';
      }, i * 30);
    });

    loadMoreWrap.classList.toggle('hidden', matching.length <= visibleCount);
  });

  // ── Lightbox ───────────────────────────────────────────────────────────────
  const lb        = document.getElementById('gallery-lightbox')!;
  const lbMedia   = document.getElementById('lightbox-media')!;
  const lbCat     = document.getElementById('lightbox-cat')!;
  const lbTech    = document.getElementById('lightbox-tech')!;
  const lbCounter = document.getElementById('lightbox-counter')!;
  const btnClose  = lb.querySelector<HTMLButtonElement>('.lightbox__close')!;
  const btnPrev   = lb.querySelector<HTMLButtonElement>('.lightbox__prev')!;
  const btnNext   = lb.querySelector<HTMLButtonElement>('.lightbox__next')!;
  const backdrop  = lb.querySelector<HTMLDivElement>('.lightbox__backdrop')!;

  let activeIndex  = 0;
  let prevFocus: HTMLElement | null = null;

  const visibleCards = () => allCards.filter(c => !c.classList.contains('hidden'));

  function renderSlide(index: number) {
    const deck = visibleCards();
    const card = deck[index];
    if (!card) return;

    const imgEl = card.querySelector<HTMLImageElement>('.gallery-card__img img');
    const src   = imgEl?.src ?? card.getAttribute('href') ?? '';
    const cat   = card.querySelector('.gallery-card__cat')?.textContent ?? '';
    const tech  = card.querySelector('.gallery-card__tech')?.textContent ?? '';

    lbCat.textContent     = cat;
    lbTech.textContent    = tech;
    lbCounter.textContent = `${index + 1} / ${deck.length}`;

    lbMedia.innerHTML = '';
    const img = new Image();
    img.alt = cat;
    img.onload = () => {
      lbMedia.innerHTML = '';
      lbMedia.appendChild(img);
    };
    img.src = src;

    btnPrev.disabled = index === 0;
    btnNext.disabled = index === deck.length - 1;
  }

  function open(index: number) {
    activeIndex = index;
    prevFocus   = document.activeElement as HTMLElement;
    lb.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    renderSlide(activeIndex);

    const shell = lb.querySelector<HTMLElement>('.lightbox__shell')!;
    shell.style.animation = 'none';
    requestAnimationFrame(() => { shell.style.animation = ''; });
    btnClose.focus();
  }

  function close() {
    lb.setAttribute('hidden', '');
    document.body.style.overflow = '';
    lbMedia.innerHTML = '';
    prevFocus?.focus();
  }

  function goTo(index: number) {
    activeIndex = index;
    renderSlide(activeIndex);
  }

  allCards.forEach(card => {
    card.addEventListener('click', e => {
      e.preventDefault();
      const deck = visibleCards();
      const idx  = deck.indexOf(card);
      if (idx !== -1) open(idx);
    });
  });

  btnClose.addEventListener('click', close);
  backdrop.addEventListener('click', close);
  btnPrev.addEventListener('click', () => { if (activeIndex > 0) goTo(activeIndex - 1); });
  btnNext.addEventListener('click', () => {
    if (activeIndex < visibleCards().length - 1) goTo(activeIndex + 1);
  });

  document.addEventListener('keydown', e => {
    if (lb.hasAttribute('hidden')) return;
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowLeft'  && activeIndex > 0)                        goTo(activeIndex - 1);
    if (e.key === 'ArrowRight' && activeIndex < visibleCards().length - 1) goTo(activeIndex + 1);
  });

  let touchStartX = 0;
  lb.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend', e => {
    const delta = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(delta) < 50) return;
    if (delta > 0 && activeIndex < visibleCards().length - 1) goTo(activeIndex + 1);
    if (delta < 0 && activeIndex > 0)                         goTo(activeIndex - 1);
  });
</script>
