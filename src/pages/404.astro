---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const homeUrl = lang === 'en' ? '/en/' : '/';
const galleryUrl = lang === 'en' ? '/en/#gallery' : '/#galeria';
---

<BaseLayout
  lang={lang}
  title={`404 · Sac_Artx`}
  description={t('notfound.desc')}
>
  <main class="notfound" aria-label="Página no encontrada">
    <!-- Watercolor blobs -->
    <div class="notfound__blobs" aria-hidden="true">
      <div class="notfound__blob notfound__blob--pink"></div>
      <div class="notfound__blob notfound__blob--teal"></div>
      <div class="notfound__blob notfound__blob--lavender"></div>

      <!-- Gold dashed ornamental lines -->
      <svg class="notfound__gold-lines" viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M 60 80 Q 200 20 380 120 T 720 80"    stroke="#C9A227" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.5"  fill="none"/>
        <path d="M 0 300 Q 150 240 300 320 T 600 280"  stroke="#C9A227" stroke-width="1"   stroke-dasharray="4 6" opacity="0.35" fill="none"/>
        <path d="M 500 480 Q 620 420 780 500"           stroke="#C9A227" stroke-width="1.5" stroke-dasharray="5 5" opacity="0.4"  fill="none"/>
      </svg>
    </div>

    <div class="notfound__inner container">
      <!-- Illustration / number -->
      <div class="notfound__visual reveal" aria-hidden="true">
        <div class="notfound__number-wrap">
          <span class="notfound__digit">4</span>
          <div class="notfound__palette">
            <!-- Simplified paintbrush SVG -->
            <svg viewBox="0 0 120 260" fill="none" xmlns="http://www.w3.org/2000/svg" class="notfound__brush" aria-hidden="true">
              <!-- Handle -->
              <rect x="52" y="60" width="16" height="160" rx="8" fill="#C9A227" opacity="0.85"/>
              <!-- Ferrule -->
              <rect x="48" y="55" width="24" height="18" rx="4" fill="#8946A6" opacity="0.9"/>
              <!-- Bristles -->
              <ellipse cx="60" cy="36" rx="18" ry="34" fill="#B762C1" opacity="0.9"/>
              <ellipse cx="60" cy="48" rx="14" ry="20" fill="#EA99D5" opacity="0.6"/>
              <!-- Paint splash -->
              <circle cx="30" cy="10" r="9"  fill="#EA99D5" opacity="0.7"/>
              <circle cx="88" cy="18" r="6"  fill="#C9A227" opacity="0.6"/>
              <circle cx="16" cy="32" r="5"  fill="#B762C1" opacity="0.5"/>
              <circle cx="100" cy="8"  r="4"  fill="#B762C1" opacity="0.55"/>
              <circle cx="72" cy="4"   r="7"  fill="#EA99D5" opacity="0.5"/>
            </svg>
          </div>
          <span class="notfound__digit">4</span>
        </div>

        <!-- Decorative gold accent bar -->
        <div class="notfound__deco" aria-hidden="true"></div>
      </div>

      <!-- Content -->
      <div class="notfound__content">
        <p class="notfound__label reveal">{t('notfound.label')}</p>
        <h1 class="notfound__title reveal">
          {t('notfound.title')}<br />
          <em>{t('notfound.titleEm')}</em>
        </h1>
        <p class="notfound__desc reveal">
          {t('notfound.desc')}
        </p>
        <div class="notfound__ctas reveal">
          <a href={homeUrl} class="btn btn-primary">
            {t('notfound.ctaPrimary')}
          </a>
          <a href={galleryUrl} class="btn btn-outline">
            {t('notfound.ctaSecondary')}
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
/* ─── Layout ──────────────────────────────────────────────────────────────── */
.notfound {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: var(--color-bg);
}

.notfound__inner {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(48px, 6vw, 96px);
  align-items: center;
  padding-top: clamp(80px, 10vw, 140px);
  padding-bottom: clamp(80px, 10vw, 140px);
}

/* ─── Blobs ───────────────────────────────────────────────────────────────── */
.notfound__blobs {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.notfound__blob {
  position: absolute;
  border-radius: 62% 38% 46% 54% / 60% 44% 56% 40%;
  filter: blur(72px);
  opacity: 0.55;
}

.notfound__blob--pink {
  width: clamp(300px, 40vw, 560px);
  height: clamp(280px, 36vw, 500px);
  background: radial-gradient(ellipse, #F5C2E8 0%, #F0A0D0 60%, transparent 100%);
  top: -120px;
  right: -80px;
  border-radius: 70% 30% 60% 40% / 50% 60% 40% 50%;
}

.notfound__blob--teal {
  width: clamp(240px, 30vw, 420px);
  height: clamp(200px, 26vw, 360px);
  background: radial-gradient(ellipse, #B2E8E0 0%, #88D8CC 60%, transparent 100%);
  bottom: -80px;
  left: -60px;
  border-radius: 40% 60% 30% 70% / 60% 40% 70% 30%;
  opacity: 0.35;
}

.notfound__blob--lavender {
  width: clamp(200px, 28vw, 400px);
  height: clamp(180px, 22vw, 320px);
  background: radial-gradient(ellipse, #EA99D5 0%, #D070C0 60%, transparent 100%);
  top: 50%;
  left: 30%;
  transform: translateY(-50%);
  opacity: 0.2;
  border-radius: 50% 50% 40% 60% / 55% 45% 60% 40%;
}

/* ─── Gold lines ──────────────────────────────────────────────────────────── */
.notfound__gold-lines {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

/* ─── Visual / number ─────────────────────────────────────────────────────── */
.notfound__visual {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.notfound__number-wrap {
  display: flex;
  align-items: center;
  gap: clamp(8px, 2vw, 20px);
  line-height: 1;
}

.notfound__digit {
  font-family: var(--font-heading);
  font-size: clamp(120px, 16vw, 220px);
  font-weight: 300;
  color: var(--color-accent);
  opacity: 0.15;
  letter-spacing: -0.04em;
  user-select: none;
}

.notfound__palette {
  display: flex;
  align-items: center;
  justify-content: center;
  width: clamp(80px, 10vw, 140px);
}

.notfound__brush {
  width: 100%;
  height: auto;
  filter: drop-shadow(0 8px 24px rgba(183, 98, 193, 0.35));
  animation: brush-float 3.5s ease-in-out infinite;
}

@keyframes brush-float {
  0%, 100% { transform: translateY(0) rotate(-4deg); }
  50%       { transform: translateY(-12px) rotate(-2deg); }
}

/* Decorative gold accent */
.notfound__deco {
  width: clamp(48px, 8vw, 80px);
  height: clamp(48px, 8vw, 80px);
  border: 2px solid var(--color-gold);
  border-radius: 4px;
  opacity: 0.45;
  box-shadow: 0 0 0 6px rgba(201, 162, 39, 0.08);
  transform: rotate(12deg);
}

/* ─── Content ─────────────────────────────────────────────────────────────── */
.notfound__content {
  display: flex;
  flex-direction: column;
  gap: clamp(16px, 2vw, 24px);
}

.notfound__label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-sage);
  transition-delay: 0.1s;
}

.notfound__label::before {
  content: '';
  display: inline-block;
  width: 24px;
  height: 1.5px;
  background: var(--color-sage);
  border-radius: 2px;
}

.notfound__title {
  font-family: var(--font-heading);
  font-size: clamp(40px, 6vw, 80px);
  font-weight: 300;
  color: var(--color-text);
  line-height: 1.1;
  transition-delay: 0.2s;
}

.notfound__title em {
  font-style: italic;
  color: var(--color-accent);
}

.notfound__desc {
  font-family: var(--font-body);
  font-size: clamp(15px, 1.4vw, 17px);
  color: var(--color-text-muted);
  line-height: 1.7;
  max-width: 44ch;
  transition-delay: 0.3s;
}

.notfound__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  transition-delay: 0.4s;
}

/* ─── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .notfound__inner {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .notfound__content {
    align-items: center;
  }

  .notfound__desc {
    max-width: 36ch;
  }

  .notfound__visual {
    order: -1;
  }

  .notfound__digit {
    font-size: clamp(80px, 20vw, 120px);
  }

  .notfound__deco {
    display: none;
  }
}

@media (max-width: 480px) {
  .notfound__ctas {
    flex-direction: column;
    width: 100%;
  }

  .notfound__ctas .btn {
    justify-content: center;
  }
}
</style>
